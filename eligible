import java.util.*;
public class Eligible 
{
    public static void main(String args[])
    {
        int age;
        Scanner sc=new Scanner(System.in);
        age=sc.nextInt();
        if((age>=18)&&(age>=40))
        {
            System.out.println("Eligible");
        }
        else
        {
            System.out.println("Not Eligible");
        }
    }
}
